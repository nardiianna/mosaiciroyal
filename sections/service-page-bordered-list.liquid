{%- style -%}
  .spbl {
    padding: 0 24px 56px;
    max-width: 900px;
    margin: 0 auto;
  }

  .spbl__title {
    text-align: center;
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 36px;
  }

  .spbl__list {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .spbl__item {
    border-left: 4px solid #e8872a;
    padding: 2px 0 2px 20px;
  }

  .spbl__item-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .spbl__item-desc {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #5a5a5a;
    margin: 0;
  }
{%- endstyle -%}

<div class="spbl">
  {%- if section.settings.title != blank -%}
    <h2 class="spbl__title">{{ section.settings.title }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="spbl__list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'list_item' -%}
          <div class="spbl__item" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="spbl__item-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="spbl__item-desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Lista con bordo",
  "tag": "section",
  "class": "service-page-bordered-list",
  "blocks": [
    {
      "type": "list_item",
      "name": "Voce",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titolo",
          "default": "Titolo voce"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descrizione"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titolo sezione",
      "default": "Tipologie"
    }
  ],
  "presets": [
    {
      "name": "Lista con bordo"
    }
  ]
}
{% endschema %}
