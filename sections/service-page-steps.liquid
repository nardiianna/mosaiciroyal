{%- style -%}
  .sps-steps {
    padding: 0 24px 64px;
    max-width: 900px;
    margin: 0 auto;
  }

  .sps-steps__title {
    text-align: center;
    font-size: 1.6rem;
    font-weight: 700;
    margin: 0 0 48px;
    color: #1a1a1a;
  }

  .sps-steps__list {
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  .sps-steps__item {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 20px;
    align-items: flex-start;
  }

  .sps-steps__icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #e8872a;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sps-steps__icon svg {
    width: 24px;
    height: 24px;
    color: #ffffff;
  }

  .sps-steps__content {
    padding-top: 4px;
  }

  .sps-steps__step-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 10px;
    line-height: 1.3;
  }

  .sps-steps__step-desc {
    font-size: 0.925rem;
    line-height: 1.7;
    color: #5a5a5a;
    margin: 0;
  }

  @media (max-width: 599px) {
    .sps-steps__item {
      grid-template-columns: 44px 1fr;
      gap: 14px;
    }

    .sps-steps__icon {
      width: 44px;
      height: 44px;
    }

    .sps-steps__icon svg {
      width: 20px;
      height: 20px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign icon_lightbulb = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18h6M10 22h4M12 2a7 7 0 0 1 7 7c0 2.6-1.4 4.8-3.5 6L15 17H9l-.5-2C6.4 13.8 5 11.6 5 9a7 7 0 0 1 7-7z"/></svg>'
  assign icon_pencil = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>'
  assign icon_palette = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>'
  assign icon_check = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>'
  assign icon_star = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
  assign icon_tools = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>'
-%}

<div class="sps-steps">
  {%- if section.settings.title != blank -%}
    <h2 class="sps-steps__title">{{ section.settings.title }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="sps-steps__list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- liquid
            case block.settings.icon
              when 'lightbulb'
                assign icon_svg = icon_lightbulb
              when 'pencil'
                assign icon_svg = icon_pencil
              when 'palette'
                assign icon_svg = icon_palette
              when 'check'
                assign icon_svg = icon_check
              when 'star'
                assign icon_svg = icon_star
              when 'tools'
                assign icon_svg = icon_tools
              else
                assign icon_svg = icon_pencil
            endcase
          -%}
          <div class="sps-steps__item" {{ block.shopify_attributes }}>
            <div class="sps-steps__icon">
              {{ icon_svg }}
            </div>
            <div class="sps-steps__content">
              {%- if block.settings.title != blank -%}
                <h3 class="sps-steps__step-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="sps-steps__step-desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Processo a step",
  "tag": "section",
  "class": "service-page-steps",
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icona",
          "options": [
            { "value": "lightbulb", "label": "Lampadina" },
            { "value": "pencil", "label": "Matita" },
            { "value": "palette", "label": "Palette" },
            { "value": "check", "label": "Spunta" },
            { "value": "star", "label": "Stella" },
            { "value": "tools", "label": "Strumenti" }
          ],
          "default": "pencil"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titolo",
          "default": "Step"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descrizione"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titolo sezione",
      "default": "Il Processo"
    }
  ],
  "presets": [
    {
      "name": "Processo a step",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "icon": "lightbulb",
            "title": "1. Concept Iniziale",
            "description": "Analizziamo le tue idee, lo spazio di destinazione e lo stile desiderato."
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "pencil",
            "title": "2. Bozze e Schizzi",
            "description": "Creiamo diverse proposte grafiche per permetterti di scegliere."
          }
        }
      ]
    }
  ]
}
{% endschema %}
