{%- style -%}
  .about-values-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .about-values-{{ section.id }} .about-values__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 40px;
  }

  @media (max-width: 749px) {
    .about-values-{{ section.id }} .about-values__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .about-values-{{ section.id }} .about-values__item {
    text-align: center;
  }

  .about-values-{{ section.id }} .about-values__icon-wrap {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background-color: {{ section.settings.icon_background }};
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }

  .about-values-{{ section.id }} .about-values__icon-wrap svg {
    fill: none;
    stroke: {{ section.settings.icon_color }};
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .about-values-{{ section.id }} .about-values__item-heading {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-foreground);
    margin: 0 0 12px;
  }

  .about-values-{{ section.id }} .about-values__item-text {
    color: var(--color-foreground);
    opacity: 0.75;
    line-height: 1.6;
    margin: 0;
  }
{%- endstyle -%}

<div class="section-background" style="background-color: {{ section.settings.background_color }};"></div>
<div class="section section--page-width about-values-{{ section.id }}">
  <div class="about-values__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'value_item' -%}
        <div class="about-values__item" {{ block.shopify_attributes }}>

          <div class="about-values__icon-wrap">
            {%- case block.settings.icon -%}
              {%- when 'award' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" aria-hidden="true">
                  <circle cx="12" cy="8" r="6"/>
                  <path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
                </svg>
              {%- when 'team' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
              {%- when 'heart' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              {%- when 'star' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" aria-hidden="true">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              {%- when 'tool' -%}
                <svg width="32" height="32" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                </svg>
              {%- else -%}
                <svg width="32" height="32" viewBox="0 0 24 24" aria-hidden="true">
                  <circle cx="12" cy="8" r="6"/>
                  <path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
                </svg>
            {%- endcase -%}
          </div>

          {%- if block.settings.heading != blank -%}
            <h3 class="about-values__item-heading">{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="about-values__item-text">{{ block.settings.text }}</p>
          {%- endif -%}

        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Chi siamo - Valori",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "value_item",
      "name": "Valore",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icona",
          "options": [
            { "value": "award", "label": "Medaglia / Premio" },
            { "value": "team", "label": "Team / Persone" },
            { "value": "heart", "label": "Cuore / Passione" },
            { "value": "star", "label": "Stella" },
            { "value": "tool", "label": "Strumento" }
          ],
          "default": "award"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Titolo",
          "default": "Eccellenza Artigianale"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descrizione",
          "default": "Ogni opera è realizzata con la massima cura e attenzione ai dettagli, seguendo le tecniche tradizionali del mosaico."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Colore sfondo",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Sfondo icona",
      "default": "#E8872A"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Colore icona",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Colonne",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "header",
      "content": "Spaziatura"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superiore",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferiore",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Chi siamo - Valori"
    }
  ]
}
{% endschema %}
