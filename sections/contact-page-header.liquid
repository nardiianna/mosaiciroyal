{%- style -%}
  .contact-page-header-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    text-align: center;
  }

  .contact-page-header-{{ section.id }} .cph__heading {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-foreground);
    margin: 0 0 20px;
  }

  .contact-page-header-bg-{{ section.id }} {
    background: radial-gradient(ellipse 80% 100% at 50% 0%, {{ section.settings.gradient_color }} 0%, #ffffff 100%);
  }

  .contact-page-header-{{ section.id }} .cph__subheading {
    color: var(--color-foreground);
    opacity: 0.75;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
{%- endstyle -%}

<div class="section-background contact-page-header-bg-{{ section.id }}"></div>
<div class="section section--page-width contact-page-header-{{ section.id }}">
  <div class="cph__inner">
    {%- if section.settings.heading != blank -%}
      <h1 class="cph__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="cph__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Contatti - Header",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo",
      "default": "Contatti"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sottotitolo",
      "default": "Siamo a tua disposizione per rispondere a qualsiasi domanda e per fornirti tutte le informazioni di cui hai bisogno"
    },
    {
      "type": "color",
      "id": "gradient_color",
      "label": "Colore sfumatura",
      "default": "#fef3c7"
    },
    {
      "type": "header",
      "content": "Spaziatura"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superiore",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferiore",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Contatti - Header"
    }
  ]
}
{% endschema %}
