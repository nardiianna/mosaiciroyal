{%- style -%}
  .spfeat {
    padding: 0 24px 72px;
  }

  .spfeat__inner {
    max-width: 760px;
    margin: 0 auto;
    background: #f6f6f6;
    border-radius: 12px;
    padding: 48px 48px 40px;
  }

  .spfeat__title {
    text-align: center;
    font-size: 1.6rem;
    font-weight: 700;
    margin: 0 0 36px;
    color: #1a1a1a;
  }

  .spfeat__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px 40px;
  }

  .spfeat__item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .spfeat__item-header {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .spfeat__check {
    color: #e8872a;
    flex-shrink: 0;
    width: 18px;
    height: 18px;
  }

  .spfeat__item-title {
    font-weight: 700;
    font-size: 0.975rem;
    color: #1a1a1a;
    line-height: 1.3;
  }

  .spfeat__item-desc {
    font-size: 0.875rem;
    color: #6a6a6a;
    line-height: 1.55;
    padding-left: 28px;
    margin: 0;
  }

  @media (max-width: 599px) {
    .spfeat__inner {
      padding: 36px 24px 28px;
    }

    .spfeat__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
{%- endstyle -%}

<div class="spfeat">
  <div class="spfeat__inner">
    {%- if section.settings.title != blank -%}
      <h2 class="spfeat__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="spfeat__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature_item' -%}
            <div class="spfeat__item" {{ block.shopify_attributes }}>
              <div class="spfeat__item-header">
                <svg class="spfeat__check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span class="spfeat__item-title">{{ block.settings.title }}</span>
              </div>
              {%- if block.settings.description != blank -%}
                <p class="spfeat__item-desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Griglia caratteristiche",
  "tag": "section",
  "class": "service-page-features",
  "blocks": [
    {
      "type": "feature_item",
      "name": "Caratteristica",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titolo",
          "default": "Caratteristica"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Descrizione",
          "default": "Breve descrizione della caratteristica"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titolo sezione",
      "default": "Cosa Offriamo"
    }
  ],
  "presets": [
    {
      "name": "Griglia caratteristiche",
      "blocks": [
        {
          "type": "feature_item",
          "settings": {
            "title": "Consultazione Iniziale",
            "description": "Incontro per comprendere le tue esigenze e visioni"
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "title": "Progetto su Misura",
            "description": "Creazione di bozzetti dettagliati del tuo mosaico"
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "title": "Scelta Materiali",
            "description": "Selezione guidata tra vetri, marmi e pietre naturali"
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "title": "Realizzazione Artigianale",
            "description": "Lavorazione completamente manuale da maestri artigiani"
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "title": "Dimensioni Personalizzate",
            "description": "Dal piccolo formato al pannello murale di grandi dimensioni"
          }
        },
        {
          "type": "feature_item",
          "settings": {
            "title": "Assistenza Completa",
            "description": "Supporto in ogni fase del progetto fino alla consegna"
          }
        }
      ]
    }
  ]
}
{% endschema %}
