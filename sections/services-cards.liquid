{%- style -%}
  .services-cards-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .services-cards-{{ section.id }} .sc__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .services-cards-{{ section.id }} .sc__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: var(--color-foreground);
    margin: 0 0 16px;
  }

  .services-cards-{{ section.id }} .sc__subheading {
    color: var(--color-foreground);
    opacity: 0.7;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .services-cards-{{ section.id }} .sc__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 24px;
  }

  @media (max-width: 899px) {
    .services-cards-{{ section.id }} .sc__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 599px) {
    .services-cards-{{ section.id }} .sc__grid {
      grid-template-columns: 1fr;
    }
  }

  .services-cards-{{ section.id }} .sc__card {
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .services-cards-{{ section.id }} .sc__card-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    flex-shrink: 0;
  }

  .services-cards-{{ section.id }} .sc__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .services-cards-{{ section.id }} .sc__card:hover .sc__card-image img {
    transform: scale(1.04);
  }

  .services-cards-{{ section.id }} .sc__card-image--placeholder {
    background: #f0ede8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .services-cards-{{ section.id }} .sc__card-body {
    padding: 24px 28px 28px;
    text-align: center;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .services-cards-{{ section.id }} .sc__card-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-foreground);
    margin: 0 0 12px;
  }

  .services-cards-{{ section.id }} .sc__card-text {
    color: var(--color-foreground);
    opacity: 0.7;
    line-height: 1.6;
    margin: 0 0 20px;
    flex-grow: 1;
  }

  .services-cards-{{ section.id }} .sc__card-link {
    color: {{ section.settings.link_color }};
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap 0.2s;
  }

  .services-cards-{{ section.id }} .sc__card-link:hover {
    gap: 10px;
  }
{%- endstyle -%}

<div class="section-background" style="background-color: {{ section.settings.background_color }};"></div>
<div class="section section--page-width services-cards-{{ section.id }}">

  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="sc__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="sc__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="sc__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="sc__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'service_card' -%}
        <div class="sc__card" {{ block.shopify_attributes }}>

          <div class="sc__card-image{% unless block.settings.image %} sc__card-image--placeholder{% endunless %}">
            {%- if block.settings.image -%}
              {{- block.settings.image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                widths: '400, 600, 800',
                sizes: '(min-width: 900px) 30vw, (min-width: 600px) 45vw, 90vw',
                alt: block.settings.image.alt | default: block.settings.title
              -}}
            {%- else -%}
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
              </svg>
            {%- endif -%}
          </div>

          <div class="sc__card-body">
            {%- if block.settings.title != blank -%}
              <h3 class="sc__card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="sc__card-text">{{ block.settings.text }}</p>
            {%- endif -%}
            {%- if block.settings.link_url != blank -%}
              <a class="sc__card-link" href="{{ block.settings.link_url }}">
                {{ block.settings.link_label | default: 'Scopri di più' }}
                <span aria-hidden="true">→</span>
              </a>
            {%- endif -%}
          </div>

        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

</div>

{% schema %}
{
  "name": "Servizi - Cards",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "service_card",
      "name": "Servizio",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Immagine"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titolo",
          "default": "Personalizzazione"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descrizione",
          "default": "Creiamo mosaici su misura secondo le tue esigenze, dal design ai materiali"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link bottone"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Testo link",
          "default": "Scopri di più"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo sezione",
      "default": "I Nostri Servizi"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sottotitolo",
      "default": "Dalla progettazione alla realizzazione, offriamo soluzioni complete per ogni esigenza"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Colonne",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Sfondo sezione",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Colore link",
      "default": "#E8872A"
    },
    {
      "type": "header",
      "content": "Spaziatura"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superiore",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferiore",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Servizi - Cards"
    }
  ]
}
{% endschema %}
