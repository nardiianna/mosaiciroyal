{%- style -%}
  .spcta {
    padding: 0 24px 80px;
  }

  .spcta__box {
    max-width: 760px;
    margin: 0 auto;
    background: #fdf6ee;
    border-left: 4px solid #e8872a;
    border-radius: 4px;
    padding: 52px 48px;
    text-align: center;
  }

  .spcta__title {
    font-size: 1.7rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 16px;
  }

  .spcta__text {
    font-size: 0.95rem;
    line-height: 1.65;
    color: #5a5a5a;
    max-width: 520px;
    margin: 0 auto 32px;
  }

  .spcta__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #e8872a;
    color: #ffffff;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 14px 36px;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }

  .spcta__btn:hover {
    background: #d4751e;
    transform: scale(1.03);
  }

  .spcta__btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  @media (max-width: 599px) {
    .spcta__box {
      padding: 40px 24px;
    }
  }
{%- endstyle -%}

<div class="spcta">
  <div class="spcta__box">
    {%- if section.settings.title != blank -%}
      <h2 class="spcta__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="spcta__text">{{ section.settings.text }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_url | default: '#' }}" class="spcta__btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <polyline points="2,4 12,13 22,4"/>
        </svg>
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "CTA contattaci",
  "tag": "section",
  "class": "service-page-cta",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titolo",
      "default": "Richiedi un Preventivo"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Testo",
      "default": "Contattaci per discutere del tuo progetto personalizzato e ricevere un preventivo gratuito senza impegno"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Testo bottone",
      "default": "Contattaci"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Link bottone"
    }
  ],
  "presets": [
    {
      "name": "CTA contattaci"
    }
  ]
}
{% endschema %}
