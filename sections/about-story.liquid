{%- style -%}
  .about-story-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .about-story-{{ section.id }} .about-story__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .about-story-{{ section.id }} .about-story__heading {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--color-foreground);
    margin: 0 0 16px;
  }

  .about-story-{{ section.id }} .about-story__accent {
    width: 60px;
    height: 3px;
    background-color: {{ section.settings.accent_color }};
    margin: 0 auto;
    border-radius: 2px;
  }

  .about-story-{{ section.id }} .about-story__content {
    max-width: 800px;
    margin: 0 auto;
  }

  .about-story-{{ section.id }} .about-story__paragraph {
    color: var(--color-foreground);
    line-height: 1.8;
    margin: 0 0 20px;
  }

  .about-story-{{ section.id }} .about-story__paragraph:last-child {
    margin-bottom: 0;
  }
{%- endstyle -%}

<div class="section-background"></div>
<div class="section section--page-width about-story-{{ section.id }}">
  <div class="about-story__inner">

    {%- if section.settings.heading != blank -%}
      <div class="about-story__header">
        <h2 class="about-story__heading">{{ section.settings.heading }}</h2>
        <div class="about-story__accent"></div>
      </div>
    {%- endif -%}

    <div class="about-story__content">
      {%- if section.settings.paragraph_1 != blank -%}
        <p class="about-story__paragraph">{{ section.settings.paragraph_1 }}</p>
      {%- endif -%}
      {%- if section.settings.paragraph_2 != blank -%}
        <p class="about-story__paragraph">{{ section.settings.paragraph_2 }}</p>
      {%- endif -%}
      {%- if section.settings.paragraph_3 != blank -%}
        <p class="about-story__paragraph">{{ section.settings.paragraph_3 }}</p>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Chi siamo - Storia",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo sezione",
      "default": "La Nostra Storia"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Colore accento",
      "default": "#E8872A"
    },
    {
      "type": "header",
      "content": "Testo"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragrafo 1",
      "default": "Royal Mosaici nasce dalla passione per l'arte del mosaico e dalla volontà di preservare e rinnovare questa antica tradizione artigianale. Da oltre vent'anni creiamo opere uniche che uniscono maestria tecnica e sensibilità artistica."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragrafo 2",
      "default": "Ogni nostra creazione è il risultato di un lavoro meticoloso, dove ogni tessera viene selezionata e posizionata a mano per dare vita a composizioni armoniose e raffinate. Utilizziamo esclusivamente materiali di prima qualità: vetri veneziani, marmi pregiati, pietre naturali e smalti artigianali."
    },
    {
      "type": "textarea",
      "id": "paragraph_3",
      "label": "Paragrafo 3",
      "default": "Il nostro team è composto da maestri mosaicisti con decenni di esperienza, affiancati da giovani artisti che portano nuove visioni e tecniche contemporanee. Questa fusione tra tradizione e innovazione ci permette di realizzare opere che rispettano l'arte antica del mosaico pur mantenendo un'estetica moderna e attuale."
    },
    {
      "type": "header",
      "content": "Spaziatura"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding superiore",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding inferiore",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Chi siamo - Storia"
    }
  ]
}
{% endschema %}
