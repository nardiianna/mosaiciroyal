{%- style -%}
  .spsp {
    padding: 0;
  }

  .spsp__intro {
    text-align: center;
    max-width: 760px;
    margin: 0 auto;
    padding: 64px 24px 56px;
  }

  .spsp__intro-text {
    font-size: 1.05rem;
    line-height: 1.75;
    color: #4a4a4a;
    margin: 0;
  }

  .spsp__grid {
    display: grid;
    grid-template-columns: {{ section.settings.image_width }}fr {{ 10 | minus: section.settings.image_width }}fr;
    gap: 48px;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 48px 72px;
  }

  .spsp__image-wrap img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ section.settings.image_radius }}px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
  }

  .spsp__image-placeholder {
    width: 100%;
    aspect-ratio: 1;
    background: #e8e8e8;
    border-radius: {{ section.settings.image_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #aaa;
    font-size: 0.875rem;
  }

  .spsp__text {
    padding: 0 8px;
  }

  .spsp__text h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    line-height: 1.25;
    margin: 0 0 24px;
    color: #1a1a1a;
  }

  .spsp__text p {
    font-size: 0.95rem;
    line-height: 1.75;
    color: #4a4a4a;
    margin: 0 0 16px;
  }

  .spsp__text p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 767px) {
    .spsp__grid {
      grid-template-columns: 1fr;
      padding: 0 20px 56px;
      gap: 28px;
    }

    .spsp__intro {
      padding: 48px 20px 36px;
    }
  }
{%- endstyle -%}

<div class="spsp">
  {%- if section.settings.intro_text != blank -%}
    <div class="spsp__intro">
      <p class="spsp__intro-text">{{ section.settings.intro_text }}</p>
    </div>
  {%- endif -%}

  <div class="spsp__grid">
    <div class="spsp__image-wrap">
      {%- if section.settings.image != blank -%}
        {{- section.settings.image
          | image_url: width: 800
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800',
            sizes: '(min-width: 768px) 45vw, 90vw',
            alt: section.settings.image.alt | default: section.settings.heading
        -}}
      {%- else -%}
        <div class="spsp__image-placeholder">Aggiungi un'immagine</div>
      {%- endif -%}
    </div>

    <div class="spsp__text">
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text_1 != blank -%}
        <p>{{ section.settings.text_1 }}</p>
      {%- endif -%}
      {%- if section.settings.text_2 != blank -%}
        <p>{{ section.settings.text_2 }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Testo con immagine",
  "tag": "section",
  "class": "service-page-split",
  "settings": [
    {
      "type": "header",
      "content": "Introduzione"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Testo introduttivo (centrato)",
      "default": "Creiamo mosaici completamente personalizzati secondo le tue esigenze, trasformando le tue idee in opere d'arte uniche e irripetibili"
    },
    {
      "type": "header",
      "content": "Immagine e testo"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Immagine"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 3,
      "max": 7,
      "step": 1,
      "label": "Larghezza immagine (colonne su 10)",
      "default": 4
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Raggio angoli immagine",
      "default": 4
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo",
      "default": "Il Tuo Mosaico su Misura"
    },
    {
      "type": "textarea",
      "id": "text_1",
      "label": "Primo paragrafo",
      "default": "Ogni cliente ha gusti e necessità uniche. Il nostro servizio di personalizzazione ti permette di creare un mosaico che rispecchia perfettamente la tua visione artistica e si integra armoniosamente con il tuo ambiente."
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "Secondo paragrafo",
      "default": "Dalla scelta dei colori alla selezione dei materiali, dalla dimensione al soggetto rappresentato, ogni aspetto può essere personalizzato per soddisfare le tue preferenze."
    }
  ],
  "presets": [
    {
      "name": "Testo con immagine"
    }
  ]
}
{% endschema %}
